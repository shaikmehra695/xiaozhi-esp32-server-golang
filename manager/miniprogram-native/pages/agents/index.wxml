<view class="container">
  <view class="card">
    <view class="title">我的智能体</view>
    <view class="muted">共 {{list.length}} 个</view>
  </view>

  <view class="card" wx:for="{{list}}" wx:key="id">
    <view class="list-item">名称：{{item.name || '-'}}</view>
    <view class="list-item">角色：{{item.role_name || '-'}}</view>
    <view>ID：{{item.id}}</view>
  </view>

  <view class="muted" wx:if="{{loading}}">加载中...</view>
</view>
